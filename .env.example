NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=beehaive-dev
NEO4J_AUTH=neo4j/beehaive-dev

# vLLM-MLX (lokale AI server op Apple Silicon)
VLLM_BASE_URL=http://localhost:8100/v1
VLLM_API_KEY=dummy-key
LLM_MODEL=mlx-community/Qwen3.5-9B-4bit
EMBEDDING_MODEL=mlx-community/multilingual-e5-large-mlx
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKENS=512

# RAG-Anything / LightRAG
RAG_WORKING_DIR=./rag_storage
RAG_WORKSPACE=beehaive

# RAG API key (verplicht in productie — fail-closed als niet gezet)
# RAG_API_KEY=your-secret-key-here
RAG_DEV_MODE=true
