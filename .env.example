NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=beehaive-dev
NEO4J_AUTH=neo4j/beehaive-dev

# LightRAG verwacht NEO4J_USERNAME (niet NEO4J_USER)
NEO4J_USERNAME=neo4j

# Gemini API (Google AI Studio) — ADR-2026-003
# Haal je key op via https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# LLM configuratie (OpenAI-compatible endpoint)
# Defaults wijzen naar Gemini — override voor andere providers
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_DIM=768
# EMBEDDING_MAX_TOKENS=2048

# RAG-Anything / LightRAG
RAG_WORKING_DIR=./rag_storage
RAG_WORKSPACE=beehaive

# RAG API key (verplicht in productie — fail-closed als niet gezet)
# RAG_API_KEY=your-secret-key-here
RAG_DEV_MODE=true
