{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beehaive.org/schemas/jeugdzorg/bezetting-aanlevering.json",
  "title": "Bezetting Aanlevering",
  "description": "Schema voor periodieke bezettingsdata aanlevering door jeugdzorgaanbieders. Klantperspectief: deze data bepaalt of er plek is voor een jeugdige.",
  "type": "object",
  "required": [
    "aanbieder_agb",
    "locatie_id",
    "peildatum",
    "totale_capaciteit",
    "bezette_plekken",
    "beschikbare_plekken",
    "type_verblijf"
  ],
  "properties": {
    "aanbieder_agb": {
      "type": "string",
      "pattern": "^\\d{8}$",
      "description": "AGB-code van de aanbieder (8 cijfers)"
    },
    "locatie_id": {
      "type": "string",
      "description": "Unieke identificatie van de verblijfslocatie"
    },
    "peildatum": {
      "type": "string",
      "format": "date",
      "description": "Datum waarop de data betrekking heeft"
    },
    "frequentie": {
      "type": "string",
      "enum": ["dag", "week", "maand"],
      "description": "Aanleverfrequentie"
    },
    "totale_capaciteit": {
      "type": "integer",
      "minimum": 0,
      "description": "Totaal aantal verblijfsplekken op deze locatie"
    },
    "bezette_plekken": {
      "type": "integer",
      "minimum": 0,
      "description": "Aantal plekken dat op de peildatum bezet is"
    },
    "beschikbare_plekken": {
      "type": "integer",
      "minimum": 0,
      "description": "Aantal plekken dat op de peildatum beschikbaar is"
    },
    "wachtlijst_aantal": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Aantal jeugdigen op de wachtlijst"
    },
    "gemiddelde_wachttijd_dagen": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Gemiddelde wachttijd in dagen"
    },
    "type_verblijf": {
      "type": "string",
      "enum": ["PLG", "GZH", "RES", "GJJ", "CRS", "KTW"],
      "description": "Type verblijf conform codelijst: PLG=Pleegzorg, GZH=Gezinshuis, RES=Residentieel, GJJ=Gesloten, CRS=Crisis, KTW=Kamertraining"
    },
    "zorgzwaarte": {
      "type": ["string", "null"],
      "enum": ["ZZ1", "ZZ2", "ZZ3", "ZZ4", null],
      "description": "Zorgzwaarte: ZZ1=Licht, ZZ2=Regulier, ZZ3=Intensief, ZZ4=Hoog-specialistisch"
    },
    "opmerkingen": {
      "type": ["string", "null"],
      "description": "Vrij tekstveld voor toelichting"
    }
  },
  "additionalProperties": false
}
