---
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildingBlocksGrid from '../components/BuildingBlocksGrid.astro';
import GuardrailTimeline from '../components/GuardrailTimeline.astro';
---

<BaseLayout title="Framework — BeeHaive">
  <section class="page-hero">
    <div class="section-eyebrow">Het Framework</div>
    <h1>7 bouwstenen.<br/>7 waarborgen.</h1>
    <p class="page-intro">Het BeeHaive-framework structureert AI-kennis in building blocks voor wat je bouwt en guardrails voor hoe je het verantwoord doet.</p>
  </section>

  <BuildingBlocksGrid />
  <GuardrailTimeline />
</BaseLayout>

<style>
  .page-hero {
    padding: 8rem 5% 4rem;
    position: relative;
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .section-eyebrow::after {
    content: '';
    width: 32px;
    height: 1.5px;
    background: var(--teal);
    opacity: 0.5;
  }

  h1 {
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .page-intro {
    font-size: 1.12rem;
    line-height: 1.8;
    color: var(--text-dim);
    max-width: 600px;
    font-weight: 300;
  }
</style>
