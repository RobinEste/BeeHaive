---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kennisbank — BeeHaive">
  <section class="page-hero">
    <div class="eyebrow">Kennisbank</div>
    <h1>Papers, regulering<br/>en best practices.</h1>
    <p class="page-intro">Gecureerde bronnen uit de AI-wereld — direct gekoppeld aan de BeeHaive building blocks en guardrails.</p>
  </section>

  <section class="knowledge-placeholder">
    <p>Kennisbank wordt gevuld vanuit de API. Binnenkort beschikbaar.</p>
  </section>
</BaseLayout>

<style>
  .knowledge-placeholder {
    padding: 4rem 5% 7rem;
    color: var(--text-muted);
    font-style: italic;
  }
</style>
