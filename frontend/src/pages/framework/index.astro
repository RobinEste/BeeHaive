---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildingBlocksGrid from '../../components/BuildingBlocksGrid.astro';
import GuardrailTimeline from '../../components/GuardrailTimeline.astro';
import AuditWorkflow from '../../components/AuditWorkflow.tsx';
import BBRelationExplorer from '../../components/BBRelationExplorer.astro';
import GlossaryTooltip from '../../components/bb-detail/GlossaryTooltip.astro';
---

<BaseLayout title="Framework — BeeHaive">
  <div class="hero-quote">
    <blockquote>"Humanity is about to be handed almost unimaginable power, and it is deeply unclear whether our social, political, and technological systems possess the maturity to wield it."</blockquote>
    <cite>— Dario Amodei</cite>
  </div>
  <section class="page-hero">
    <div class="eyebrow">Het Framework</div>
    <h1>7 bouwstenen.<br/>7 waarborgen.</h1>
    <p class="page-intro">Het BeeHaive-framework structureert AI-kennis in building blocks voor wat je bouwt en guardrails voor hoe je het verantwoord doet.</p>
  </section>

  <section class="explorer-section">
    <div class="eyebrow">Verkennen</div>
    <h2 class="section-title">De bouwstenen onderling</h2>
    <p class="section-intro">Klik op een bouwsteen voor een korte toelichting. Klik daarna op een tweede bouwsteen om te zien hoe ze samenwerken.</p>
    <BBRelationExplorer />
  </section>

  <BuildingBlocksGrid />

  <section class="workflow-section">
    <div class="eyebrow">In de praktijk</div>
    <h2 class="section-title">AI-Readiness Audit</h2>
    <p class="section-intro">Hoe werken de building blocks samen in een echt project? Hieronder kun je stap-voor-stap door een concrete use-case heen lopen: AI-Readiness Audit. Je ziet per processtap onze gedachten en daaronder de building blocks die we gebruikten met toelichting. Klik op de blokjes om te starten.</p>
    <AuditWorkflow client:visible />
  </section>

  <GuardrailTimeline />
  <GlossaryTooltip />
</BaseLayout>

<style>
  .workflow-section {
    background: linear-gradient(rgba(12, 30, 29, 0.85), rgba(12, 30, 29, 0.92)), url('https://images.unsplash.com/photo-1494522855154-9297ac14b55f?w=1920&q=80') center/cover no-repeat;
    padding: 4rem 5%;
    border-top: 1px solid var(--border);
  }
  .explorer-section {
    padding: 3rem 5% 1rem;
    border-top: 1px solid var(--border);
  }
</style>
