      <g class="bbre-node" data-slug="evaluation-loop">
        <circle class="bbre-node-circle" cx="342" cy="329" r="20" fill="#0C1E1D" stroke="var(--bb-evaluation-loop)" stroke-width="1.8"/>
        <circle cx="340" cy="329" r="8" stroke="var(--bb-evaluation-loop)" stroke-width="1.4" fill="none" style="pointer-events:none"/>
        <circle cx="340" cy="329" r="4.5" stroke="var(--bb-evaluation-loop)" stroke-width="1.3" fill="none" style="pointer-events:none"/>
        <circle cx="340" cy="329" r="1.5" fill="var(--bb-evaluation-loop)" style="pointer-events:none"/>
        <line x1="346" y1="323" x2="349" y2="320" stroke="var(--bb-evaluation-loop)" stroke-width="1.3" stroke-linecap="round" style="pointer-events:none"/>
        <line x1="346" y1="320" x2="350" y2="320" stroke="var(--bb-evaluation-loop)" stroke-width="1.3" stroke-linecap="round" style="pointer-events:none"/>
        <line x1="350" y1="320" x2="350" y2="324" stroke="var(--bb-evaluation-loop)" stroke-width="1.3" stroke-linecap="round" style="pointer-events:none"/>
        <text x="368" y="323" text-anchor="start" font-family="Space Mono, monospace" font-size="8" fill="var(--bb-evaluation-loop)" opacity="0.8" letter-spacing="0.05em" style="pointer-events:none">BB_07</text>
        <text x="368" y="333" text-anchor="start" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="var(--bb-evaluation-loop)" opacity="0.55" style="pointer-events:none">Evaluation Loop</text>
      </g>
    </svg>
  </div>

  <aside class="bbre-panel" data-state="empty">
    <div class="bbre-panel-empty">
      <div class="bbre-eyebrow">Verken het framework</div>
      <h3 class="bbre-title">Klik op een bouwsteen om te beginnen.</h3>
      <p class="bbre-intro">
        Selecteer een bouwsteen om kort te lezen wat hij doet. Selecteer daarna een tweede om hun
        onderlinge relatie te zien.
      </p>
    </div>

    <div class="bbre-panel-one" hidden>
      <div class="bbre-eyebrow" data-role="code"></div>
      <h3 class="bbre-title" data-role="name"></h3>
      <div class="bbre-body" data-role="overview"></div>
      <p class="bbre-prompt">Klik op een tweede bouwsteen voor hun relatie.</p>
      <div class="bbre-actions">
        <a class="bbre-btn-primary" data-role="detail-link">Lees diepgaand →</a>
        <button class="bbre-btn-ghost" data-role="reset">Reset</button>
      </div>
    </div>

    <div class="bbre-panel-two" hidden>
      <div class="bbre-eyebrow" data-role="codes"></div>
      <h3 class="bbre-title" data-role="names"></h3>
      <div class="bbre-body" data-role="relation"></div>
      <div class="bbre-actions">
        <a class="bbre-btn-ghost-sm" data-role="link-1"></a>
        <a class="bbre-btn-ghost-sm" data-role="link-2"></a>
        <button class="bbre-btn-ghost" data-role="reset">Andere combinatie</button>
      </div>
    </div>
  </aside>
</div>

<script is:inline type="application/json" id="bbre-data" set:html={JSON.stringify(dataPayload)} />

<script>
  (() => {
    const root = document.querySelector('.bbre') as HTMLElement | null;
    const dataScript = document.getElementById('bbre-data');
    if (!root || !dataScript) return;

    const data = JSON.parse(dataScript.textContent || '{}');
    const nodeBySlug: Record<string, { slug: string; code: string; name: string }> = {};
    for (const n of data.nodes) nodeBySlug[n.slug] = n;

    const panel = root.querySelector('.bbre-panel') as HTMLElement;
    const panelEmpty = root.querySelector('.bbre-panel-empty') as HTMLElement;
    const panelOne = root.querySelector('.bbre-panel-one') as HTMLElement;
    const panelTwo = root.querySelector('.bbre-panel-two') as HTMLElement;
    const nodes = Array.from(root.querySelectorAll('.bbre-node')) as SVGGElement[];
    const edges = Array.from(root.querySelectorAll('.bbre-edge')) as SVGLineElement[];

    let first: string | null = null;
    let second: string | null = null;

    function pairKey(a: string, b: string) {
      return [a, b].sort().join('--');
    }

    function bbColor(slug: string) {
      return `var(--bb-${slug})`;
    }

    function renderParagraphs(container: HTMLElement, text: string) {
      container.innerHTML = '';
      text.split(/\n\n+/).forEach((para) => {
        const trimmed = para.trim();
        if (!trimmed) return;
        const p = document.createElement('p');
        // Tekst mag inline-HTML bevatten voor glossary-links (eigen content, geen user input)
        p.innerHTML = trimmed;
        container.appendChild(p);
      });
    }

    function setPanel(state: 'empty' | 'one' | 'two') {
      panel.dataset.state = state;
      panelEmpty.hidden = state !== 'empty';
      panelOne.hidden = state !== 'one';
      panelTwo.hidden = state !== 'two';
    }

    function render() {
      // Update nodes (radius blijft constant, alleen stroke-width en glow veranderen)
      const SPECIAL = new Set(['knowledge', 'evaluation-loop']);
      nodes.forEach((g) => {
        const slug = g.dataset.slug!;
        const isSelected = slug === first || slug === second;
        const isDimmed = first !== null && !isSelected;
        g.style.opacity = isDimmed ? '0.35' : '1';
        const circle = g.querySelector('.bbre-node-circle') as SVGCircleElement;
        const baseStroke = SPECIAL.has(slug) ? '1.8' : '1.6';
        circle.setAttribute('stroke-width', isSelected ? '2.6' : baseStroke);
        if (isSelected) circle.setAttribute('filter', 'url(#bbre-glow)');
        else circle.removeAttribute('filter');
      });

      // Update edges
      const activeEdgeKey = first && second ? pairKey(first, second) : null;
      edges.forEach((line) => {
        const k = line.dataset.edge!;
        const isActive = k === activeEdgeKey;
        const isDim = first !== null && !isActive;
        line.setAttribute('stroke-opacity', isActive ? '0.9' : isDim ? '0.08' : '0.3');
        line.setAttribute('stroke-width', isActive ? '2.4' : '1.4');
        line.setAttribute('stroke', isActive && first ? bbColor(first) : '#44C2BA');
      });

      // Synthetic edge for non-adjacent pair (drawn on top)
      let synthLine = root!.querySelector('.bbre-edge-synth') as SVGLineElement | null;
      if (first && second) {
        const directExists = edges.some((e) => e.dataset.edge === pairKey(first!, second!));
        if (!directExists) {
          if (!synthLine) {
            const svgNS = 'http://www.w3.org/2000/svg';
            synthLine = document.createElementNS(svgNS, 'line') as SVGLineElement;
            synthLine.setAttribute('class', 'bbre-edge-synth');
            const svg = root!.querySelector('svg')!;
            svg.appendChild(synthLine);
          }
          const aCircle = root!.querySelector(`.bbre-node[data-slug="${first}"] .bbre-node-circle`) as SVGCircleElement;
          const bCircle = root!.querySelector(`.bbre-node[data-slug="${second}"] .bbre-node-circle`) as SVGCircleElement;
          synthLine.setAttribute('x1', aCircle.getAttribute('cx')!);
          synthLine.setAttribute('y1', aCircle.getAttribute('cy')!);
          synthLine.setAttribute('x2', bCircle.getAttribute('cx')!);
          synthLine.setAttribute('y2', bCircle.getAttribute('cy')!);
          synthLine.setAttribute('stroke', bbColor(first));
          synthLine.setAttribute('stroke-width', '2.4');
          synthLine.setAttribute('stroke-opacity', '0.85');
          synthLine.setAttribute('stroke-dasharray', '4 4');
        } else if (synthLine) {
          synthLine.remove();
        }
      } else if (synthLine) {
        synthLine.remove();
      }

      // Update side panel
      if (first === null) {
        setPanel('empty');
      } else if (second === null) {
        setPanel('one');
        const node = nodeBySlug[first];
        const eyebrow = panelOne.querySelector('[data-role="code"]') as HTMLElement;
        const name = panelOne.querySelector('[data-role="name"]') as HTMLElement;
        const body = panelOne.querySelector('[data-role="overview"]') as HTMLElement;
        const link = panelOne.querySelector('[data-role="detail-link"]') as HTMLAnchorElement;
        eyebrow.textContent = node.code;
        eyebrow.style.color = bbColor(node.slug);
        name.textContent = node.name;
        name.style.color = bbColor(node.slug);
        renderParagraphs(body, data.overviews[first] || '');
        link.href = `/framework/${first}`;
      } else {
        setPanel('two');
        const a = nodeBySlug[first];
        const b = nodeBySlug[second];
        const codes = panelTwo.querySelector('[data-role="codes"]') as HTMLElement;
        const names = panelTwo.querySelector('[data-role="names"]') as HTMLElement;
        const body = panelTwo.querySelector('[data-role="relation"]') as HTMLElement;
        const link1 = panelTwo.querySelector('[data-role="link-1"]') as HTMLAnchorElement;
        const link2 = panelTwo.querySelector('[data-role="link-2"]') as HTMLAnchorElement;
        codes.innerHTML = `<span style="color:${bbColor(a.slug)}">${a.code}</span> <span style="color:var(--text-muted)">×</span> <span style="color:${bbColor(b.slug)}">${b.code}</span>`;
        names.innerHTML = `<span style="color:${bbColor(a.slug)}">${a.name}</span> <span style="color:var(--text-muted)">↔</span> <span style="color:${bbColor(b.slug)}">${b.name}</span>`;
        const key = pairKey(first, second);
        renderParagraphs(body, data.relations[key] || '[Dummy] Geen relatie-tekst gevonden.');
        link1.href = `/framework/${first}`;
        link1.textContent = `${a.name} →`;
        link2.href = `/framework/${second}`;
        link2.textContent = `${b.name} →`;
      }
    }

    function reset() {
      first = null;
      second = null;
      render();
    }

    function handleNodeClick(slug: string) {
      if (first === null) {
        first = slug;
      } else if (slug === first) {
        first = null;
        second = null;
      } else if (second === null) {
        second = slug;
      } else {
        first = slug;
        second = null;
      }
      render();
    }

    nodes.forEach((g) => {
      g.style.cursor = 'pointer';
      g.addEventListener('click', () => handleNodeClick(g.dataset.slug!));
    });

    panel.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.dataset.role === 'reset') reset();
    });

    render();
  })();
</script>
