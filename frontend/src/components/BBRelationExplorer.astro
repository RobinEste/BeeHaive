        <rect x="128" y="202" width="20" height="18" rx="1.5" stroke="var(--bb-prompt-design)" stroke-width="1.3" fill="none" style="pointer-events:none"/>
        <line x1="128" y1="207.5" x2="148" y2="207.5" stroke="var(--bb-prompt-design)" stroke-width="1.2" style="pointer-events:none"/>
        <line x1="138" y1="207.5" x2="138" y2="220" stroke="var(--bb-prompt-design)" stroke-width="1.1" style="pointer-events:none"/>
        <line x1="131" y1="211" x2="136" y2="211" stroke="var(--bb-prompt-design)" stroke-width="0.9" stroke-linecap="round" style="pointer-events:none"/>
        <line x1="131" y1="214" x2="136" y2="214" stroke="var(--bb-prompt-design)" stroke-width="0.9" stroke-linecap="round" style="pointer-events:none"/>
        <line x1="140" y1="211" x2="146" y2="211" stroke="var(--bb-prompt-design)" stroke-width="0.9" stroke-linecap="round" style="pointer-events:none"/>
        <line x1="140" y1="214" x2="146" y2="214" stroke="var(--bb-prompt-design)" stroke-width="0.9" stroke-linecap="round" style="pointer-events:none"/>
        <text x="112" y="205" text-anchor="end" font-family="Space Mono, monospace" font-size="8" fill="var(--bb-prompt-design)" opacity="0.7" letter-spacing="0.05em" style="pointer-events:none">BB_04</text>
        <text x="112" y="215" text-anchor="end" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="var(--bb-prompt-design)" opacity="0.5" style="pointer-events:none">Prompt Design</text>
      </g>

      {/* BB_05 Tool Integration — bottom-left (image icon) */}
      <g class="bbre-node" data-slug="tool-integration">
        <circle class="bbre-node-circle" cx="138" cy="329" r="20" fill="#0C1E1D" stroke="var(--bb-tool-integration)" stroke-width="1.6"/>
        <image href="/icons/bb-tool-integration.png" x="126" y="317" width="24" height="24" style="mix-blend-mode:screen;pointer-events:none"/>
        <text x="112" y="323" text-anchor="end" font-family="Space Mono, monospace" font-size="8" fill="var(--bb-tool-integration)" opacity="0.7" letter-spacing="0.05em" style="pointer-events:none">BB_05</text>
        <text x="112" y="333" text-anchor="end" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="var(--bb-tool-integration)" opacity="0.5" style="pointer-events:none">Tool Integration</text>
      </g>

      {/* BB_06 Model Engines — bottom (image icon) */}
      <g class="bbre-node" data-slug="model-engines">
        <circle class="bbre-node-circle" cx="240" cy="388" r="20" fill="#0C1E1D" stroke="var(--bb-model-engines)" stroke-width="1.6"/>
        <image href="/icons/bb-model-engines.png" x="228" y="376" width="24" height="24" style="mix-blend-mode:screen;pointer-events:none"/>
        <text x="240" y="416" text-anchor="middle" font-family="Space Mono, monospace" font-size="8" fill="var(--bb-model-engines)" opacity="0.7" letter-spacing="0.05em" style="pointer-events:none">BB_06</text>
        <text x="240" y="426" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="var(--bb-model-engines)" opacity="0.5" style="pointer-events:none">Model Engines</text>
