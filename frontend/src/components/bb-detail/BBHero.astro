---
import BBIcon from './BBIcon.astro';

interface Props {
  code: string;
  name: string;
  tagline: string;
  slug: string;
  quote?: string;
  quoteAuthor?: string;
}

const { code, name, tagline, slug, quote, quoteAuthor } = Astro.props;
---

{quote && (
  <div class="hero-quote">
    <blockquote>{quote}</blockquote>
    {quoteAuthor && <cite>— {quoteAuthor}</cite>}
  </div>
)}

<section class="bb-hero">
  <nav class="breadcrumb">
    <a href="/framework">Framework</a>
    <span class="breadcrumb-sep">/</span>
    <span>{name}</span>
  </nav>
  <div class="bb-hero-title">
    <BBIcon slug={slug} size={48} class="bb-hero-icon" />
    <h1>{name}</h1>
  </div>
  <div class="bb-hero-meta">
    <span class="eyebrow">{code}</span>
    <p class="page-intro">{tagline}</p>
  </div>
</section>

<style>
  .bb-hero {
    padding: 2rem 5% 4rem;
    position: relative;
  }

  .bb-hero-title {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .bb-hero-title h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin: 0;
  }

  .bb-hero-title :global(.bb-hero-icon) {
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--accent, var(--teal)) 40%, transparent));
  }

  .bb-hero-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0;
  }

  .bb-hero-meta .eyebrow {
    margin-bottom: 0;
    flex-shrink: 0;
    color: var(--accent, var(--teal));
  }

  .bb-hero-meta .eyebrow::after {
    background: var(--accent, var(--teal));
  }

  .bb-hero-meta .page-intro {
    margin: 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--teal);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--teal-light);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  @media (max-width: 960px) {
    .bb-hero-title :global(.bb-hero-icon) {
      width: 36px !important;
      height: 36px !important;
    }
  }
</style>
