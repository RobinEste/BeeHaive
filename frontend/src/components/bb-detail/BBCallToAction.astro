---
interface Props {
  bbName: string;
}

const { bbName } = Astro.props;
---

<section class="bb-cta bb-section" id="contact">
  <div class="cta-inner">
    <h2>Wil je weten hoe jouw organisatie scoort op {bbName}?</h2>
    <p>Met een AI-Readiness Audit brengen we samen in kaart waar je staat en wat de volgende stap is.</p>
    <a href="/over" class="btn-gold">Start de audit →</a>
  </div>
</section>

<style>
  .bb-cta {}

  .cta-inner {
    background: linear-gradient(135deg, rgba(68, 194, 186, 0.1) 0%, rgba(233, 202, 98, 0.06) 100%);
    border: 1px solid var(--border-2);
    border-radius: 14px;
    padding: 3rem;
    text-align: center;
  }

  .cta-inner h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-dim);
    font-weight: 300;
    max-width: 480px;
    margin: 0 auto 2rem;
  }
</style>
