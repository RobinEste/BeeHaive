---
import type { GuardrailLink } from '../../lib/bb-guardrail-links';

interface Props {
  links: GuardrailLink[];
  bbName: string;
}

const { links, bbName } = Astro.props;
---

{links.length > 0 && (
  <section class="bb-guardrails bb-section" id="guardrails">
    <div class="eyebrow">Guardrails</div>
    <h2 class="section-title">Gekoppelde guardrails</h2>
    <p class="section-intro">
      Welke EU Trustworthy AI-waarborgen zijn het meest relevant bij {bbName}?
    </p>

    <div class="gr-cards">
      {links.map((gr) => (
        <div class="gr-card">
          <div class="gr-card-header">
            <span class="gr-code">{gr.code}</span>
            <h3>{gr.name}</h3>
          </div>
          <p class="gr-tagline">{gr.tagline}</p>
          <p class="gr-relevance">{gr.relevance}</p>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .bb-guardrails {}

  .gr-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gr-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.8rem 2rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .gr-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, var(--teal), rgba(68, 194, 186, 0.3));
    box-shadow: 0 0 10px rgba(68, 194, 186, 0.25);
  }

  .gr-card:hover {
    border-color: var(--border-2);
  }

  .gr-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .gr-code {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    background: rgba(68, 194, 186, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .gr-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: -0.02em;
  }

  .gr-tagline {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.55;
    font-weight: 300;
    margin-bottom: 0.75rem;
  }

  .gr-relevance {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.65;
    font-weight: 300;
    padding-left: 1rem;
    border-left: 2px solid var(--border-2);
  }
</style>
