---
interface Props {
  eyebrow: string;
  title: string;
  sectionId: string;
}

const { eyebrow, title, sectionId } = Astro.props;
---

<section class="bb-prose-section bb-section" id={sectionId}>
  <div class="eyebrow">{eyebrow}</div>
  <h2 class="section-title">{title}</h2>
  <div class="prose">
    <slot />
  </div>
</section>

<style>
  .prose {
    max-width: 720px;
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-dim);
    font-weight: 300;
  }

  .prose > :global(h2) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--accent, var(--teal-light));
    margin: 2.5rem 0 0.8rem;
    letter-spacing: -0.01em;
  }

  .prose > :global(h2:first-child) {
    display: none;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent, var(--teal-light));
    margin: 1.75rem 0 0.6rem;
    letter-spacing: -0.01em;
  }

  .prose :global(li > strong:first-child) {
    color: var(--accent, var(--teal-light));
    font-weight: 600;
  }

  .prose :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0.8rem 0 1.4rem;
  }

  .prose :global(ul li) {
    position: relative;
    padding-left: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(ul li::before) {
    content: "•";
    position: absolute;
    left: 0.3rem;
    top: 0;
    color: var(--accent, var(--teal));
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1.85;
  }

  .prose :global(ol) {
    padding-left: 1.4rem;
    margin: 0.8rem 0 1.4rem;
  }

  .prose :global(ol li) {
    margin-bottom: 0.5rem;
    padding-left: 0.3rem;
  }

  .prose :global(ol li::marker) {
    color: var(--accent, var(--teal));
    font-weight: 600;
  }

  .prose :global(p) {
    margin-bottom: 1.2rem;
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(strong) {
    color: inherit;
    font-weight: 600;
  }

  .prose :global(em) {
    color: var(--accent, var(--teal-light));
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--accent, var(--teal-light));
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent, var(--teal-light)) 40%, transparent);
    text-underline-offset: 0.2em;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .prose :global(a:hover) {
    color: var(--accent, var(--teal));
    text-decoration-color: currentColor;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0 1.6rem;
    font-size: 0.98rem;
  }

  .prose :global(thead th) {
    text-align: left;
    vertical-align: top;
    font-weight: 600;
    color: var(--accent, var(--teal-light));
    border-bottom: 1px solid var(--border);
    padding: 0.55rem 0.8rem 0.55rem 0;
  }

  .prose :global(tbody td) {
    text-align: left;
    vertical-align: top;
    padding: 0.55rem 0.8rem 0.55rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
  }

  .prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }
</style>
