---

<div class="hero-graph">
  <svg viewBox="35 110 410 325" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <filter id="nodeGlow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="4" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="nodeGlowGold" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="6" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <radialGradient id="haloTeal" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#44C2BA" stop-opacity="0.15"/>
        <stop offset="100%" stop-color="#44C2BA" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="haloGold" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#E9CA62" stop-opacity="0.2"/>
        <stop offset="100%" stop-color="#E9CA62" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- Edges: center → outer nodes -->
    <line x1="240" y1="270" x2="240" y2="152" stroke="#44C2BA" stroke-width="1.4" stroke-opacity="0.3"/>
    <line x1="240" y1="270" x2="342" y2="211" stroke="#44C2BA" stroke-width="1.4" stroke-opacity="0.3"/>
    <line x1="240" y1="270" x2="342" y2="329" stroke="#44C2BA" stroke-width="1.4" stroke-opacity="0.3"/>
    <line x1="240" y1="270" x2="240" y2="388" stroke="#44C2BA" stroke-width="1.4" stroke-opacity="0.3"/>
    <line x1="240" y1="270" x2="138" y2="329" stroke="#44C2BA" stroke-width="1.4" stroke-opacity="0.3"/>
    <line x1="240" y1="270" x2="138" y2="211" stroke="#44C2BA" stroke-width="1.4" stroke-opacity="0.3"/>

    <!-- Edges: outer ring -->
    <line x1="240" y1="152" x2="342" y2="211" stroke="#44C2BA" stroke-width="0.9" stroke-opacity="0.18"/>
    <line x1="342" y1="211" x2="342" y2="329" stroke="#44C2BA" stroke-width="0.9" stroke-opacity="0.18"/>
    <line x1="342" y1="329" x2="240" y2="388" stroke="#44C2BA" stroke-width="0.9" stroke-opacity="0.18"/>
    <line x1="240" y1="388" x2="138" y2="329" stroke="#44C2BA" stroke-width="0.9" stroke-opacity="0.18"/>
    <line x1="138" y1="329" x2="138" y2="211" stroke="#44C2BA" stroke-width="0.9" stroke-opacity="0.18"/>
    <line x1="138" y1="211" x2="240" y2="152" stroke="#44C2BA" stroke-width="0.9" stroke-opacity="0.18"/>

    <!-- Traveling particles along edges -->
    <defs>
      <!-- Center → outer paths -->
      <path id="p-c-02" d="M240,270 L240,152"/>
      <path id="p-c-03" d="M240,270 L342,211"/>
      <path id="p-c-07" d="M240,270 L342,329"/>
      <path id="p-c-06" d="M240,270 L240,388"/>
      <path id="p-c-05" d="M240,270 L138,329"/>
      <path id="p-c-04" d="M240,270 L138,211"/>
      <!-- Outer ring paths -->
      <path id="p-02-03" d="M240,152 L342,211"/>
      <path id="p-03-07" d="M342,211 L342,329"/>
      <path id="p-07-06" d="M342,329 L240,388"/>
      <path id="p-06-05" d="M240,388 L138,329"/>
      <path id="p-05-04" d="M138,329 L138,211"/>
      <path id="p-04-02" d="M138,211 L240,152"/>
    </defs>

    <!-- Center → outer particles (outbound) -->
    <circle r="2.5" fill="#44C2BA" opacity="0">
      <animateMotion dur="3s" repeatCount="indefinite" begin="0s"><mpath href="#p-c-02"/></animateMotion>
      <animate attributeName="opacity" values="0;0.9;0.9;0" dur="3s" repeatCount="indefinite" begin="0s"/>
    </circle>
    <circle r="2" fill="#8BE6DA" opacity="0">
      <animateMotion dur="4s" repeatCount="indefinite" begin="1.5s"><mpath href="#p-c-03"/></animateMotion>
      <animate attributeName="opacity" values="0;0.8;0.8;0" dur="4s" repeatCount="indefinite" begin="1.5s"/>
    </circle>
    <circle r="2.5" fill="#E9CA62" opacity="0">
      <animateMotion dur="3.5s" repeatCount="indefinite" begin="0.8s"><mpath href="#p-c-07"/></animateMotion>
      <animate attributeName="opacity" values="0;0.9;0.9;0" dur="3.5s" repeatCount="indefinite" begin="0.8s"/>
    </circle>
    <circle r="2" fill="#44C2BA" opacity="0">
      <animateMotion dur="4.2s" repeatCount="indefinite" begin="2.2s"><mpath href="#p-c-06"/></animateMotion>
      <animate attributeName="opacity" values="0;0.8;0.8;0" dur="4.2s" repeatCount="indefinite" begin="2.2s"/>
    </circle>

    <!-- Outer → center particles (returning, offset timing) -->
    <circle r="2" fill="#E9CA62" opacity="0">
      <animateMotion dur="3.6s" repeatCount="indefinite" begin="2s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-c-05"/></animateMotion>
      <animate attributeName="opacity" values="0;0.8;0.8;0" dur="3.6s" repeatCount="indefinite" begin="2s"/>
    </circle>
    <circle r="2.5" fill="#8BE6DA" opacity="0">
      <animateMotion dur="3.4s" repeatCount="indefinite" begin="4s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-c-04"/></animateMotion>
      <animate attributeName="opacity" values="0;0.9;0.9;0" dur="3.4s" repeatCount="indefinite" begin="4s"/>
    </circle>
    <circle r="2" fill="#44C2BA" opacity="0">
      <animateMotion dur="4.5s" repeatCount="indefinite" begin="6s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-c-02"/></animateMotion>
      <animate attributeName="opacity" values="0;0.7;0.7;0" dur="4.5s" repeatCount="indefinite" begin="6s"/>
    </circle>
    <circle r="2" fill="#E9CA62" opacity="0">
      <animateMotion dur="3.8s" repeatCount="indefinite" begin="5s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-c-03"/></animateMotion>
      <animate attributeName="opacity" values="0;0.7;0.7;0" dur="3.8s" repeatCount="indefinite" begin="5s"/>
    </circle>

    <!-- Outer ring — mixed directions per edge, crossing each other -->

    <!-- p-02-03: forward + reverse -->
    <circle r="1.8" fill="#8BE6DA" opacity="0">
      <animateMotion dur="5s" repeatCount="indefinite" begin="1s"><mpath href="#p-02-03"/></animateMotion>
      <animate attributeName="opacity" values="0;0.6;0.6;0" dur="5s" repeatCount="indefinite" begin="1s"/>
    </circle>
    <circle r="1.6" fill="#44C2BA" opacity="0">
      <animateMotion dur="5.8s" repeatCount="indefinite" begin="4s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-02-03"/></animateMotion>
      <animate attributeName="opacity" values="0;0.5;0.5;0" dur="5.8s" repeatCount="indefinite" begin="4s"/>
    </circle>

    <!-- p-03-07: forward + reverse -->
    <circle r="1.8" fill="#44C2BA" opacity="0">
      <animateMotion dur="6s" repeatCount="indefinite" begin="0.3s"><mpath href="#p-03-07"/></animateMotion>
      <animate attributeName="opacity" values="0;0.55;0.55;0" dur="6s" repeatCount="indefinite" begin="0.3s"/>
    </circle>
    <circle r="1.6" fill="#E9CA62" opacity="0">
      <animateMotion dur="5.4s" repeatCount="indefinite" begin="3.5s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-03-07"/></animateMotion>
      <animate attributeName="opacity" values="0;0.5;0.5;0" dur="5.4s" repeatCount="indefinite" begin="3.5s"/>
    </circle>

    <!-- p-07-06: forward + reverse -->
    <circle r="2" fill="#E9CA62" opacity="0">
      <animateMotion dur="5.5s" repeatCount="indefinite" begin="2s"><mpath href="#p-07-06"/></animateMotion>
      <animate attributeName="opacity" values="0;0.6;0.6;0" dur="5.5s" repeatCount="indefinite" begin="2s"/>
    </circle>
    <circle r="1.6" fill="#8BE6DA" opacity="0">
      <animateMotion dur="6.2s" repeatCount="indefinite" begin="5s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-07-06"/></animateMotion>
      <animate attributeName="opacity" values="0;0.5;0.5;0" dur="6.2s" repeatCount="indefinite" begin="5s"/>
    </circle>

    <!-- p-06-05: forward + reverse -->
    <circle r="1.8" fill="#8BE6DA" opacity="0">
      <animateMotion dur="6.5s" repeatCount="indefinite" begin="4.5s"><mpath href="#p-06-05"/></animateMotion>
      <animate attributeName="opacity" values="0;0.5;0.5;0" dur="6.5s" repeatCount="indefinite" begin="4.5s"/>
    </circle>
    <circle r="1.6" fill="#44C2BA" opacity="0">
      <animateMotion dur="5.6s" repeatCount="indefinite" begin="1.2s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-06-05"/></animateMotion>
      <animate attributeName="opacity" values="0;0.55;0.55;0" dur="5.6s" repeatCount="indefinite" begin="1.2s"/>
    </circle>

    <!-- p-05-04: forward + reverse -->
    <circle r="1.8" fill="#44C2BA" opacity="0">
      <animateMotion dur="5.8s" repeatCount="indefinite" begin="0.5s"><mpath href="#p-05-04"/></animateMotion>
      <animate attributeName="opacity" values="0;0.6;0.6;0" dur="5.8s" repeatCount="indefinite" begin="0.5s"/>
    </circle>
    <circle r="1.6" fill="#E9CA62" opacity="0">
      <animateMotion dur="6.3s" repeatCount="indefinite" begin="3.8s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-05-04"/></animateMotion>
      <animate attributeName="opacity" values="0;0.5;0.5;0" dur="6.3s" repeatCount="indefinite" begin="3.8s"/>
    </circle>

    <!-- p-04-02: forward + reverse -->
    <circle r="2" fill="#8BE6DA" opacity="0">
      <animateMotion dur="5.2s" repeatCount="indefinite" begin="3s"><mpath href="#p-04-02"/></animateMotion>
      <animate attributeName="opacity" values="0;0.55;0.55;0" dur="5.2s" repeatCount="indefinite" begin="3s"/>
    </circle>
    <circle r="1.6" fill="#44C2BA" opacity="0">
      <animateMotion dur="6.1s" repeatCount="indefinite" begin="0.8s" keyPoints="1;0" keyTimes="0;1" calcMode="linear"><mpath href="#p-04-02"/></animateMotion>
      <animate attributeName="opacity" values="0;0.5;0.5;0" dur="6.1s" repeatCount="indefinite" begin="0.8s"/>
    </circle>

    <!-- Halos -->
    <circle cx="240" cy="270" r="52" fill="url(#haloGold)"/>
    <circle cx="240" cy="152" r="38" fill="url(#haloTeal)"/>
    <circle cx="342" cy="211" r="34" fill="url(#haloTeal)"/>
    <circle cx="342" cy="329" r="34" fill="url(#haloTeal)"/>
    <circle cx="240" cy="388" r="34" fill="url(#haloTeal)"/>
    <circle cx="138" cy="329" r="34" fill="url(#haloTeal)"/>
    <circle cx="138" cy="211" r="34" fill="url(#haloTeal)"/>

    <!-- BB_01 Knowledge — center, gold -->
    <g class="graph-node" filter="url(#nodeGlowGold)">
      <circle cx="240" cy="270" r="20" fill="#0C1E1D" stroke="#E9CA62" stroke-width="1.8"/>
      <image href="/icons/bb-knowledge.png" x="228" y="258" width="24" height="24" style="mix-blend-mode:screen"/>
      <animate attributeName="opacity" values="0.9;1;0.9" dur="4s" repeatCount="indefinite"/>
    </g>
    <text x="240" y="302" text-anchor="middle" font-family="Space Mono, monospace" font-size="8.5" fill="#E9CA62" opacity="0.8" letter-spacing="0.06em">BB_01</text>
    <text x="240" y="313" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="9" fill="#E9CA62" opacity="0.55">Knowledge</text>

    <!-- BB_02 Client Blueprint — top center (speech bubble + pen) -->
    <g class="graph-node" filter="url(#nodeGlow)">
      <circle cx="240" cy="152" r="20" fill="#0C1E1D" stroke="#44C2BA" stroke-width="1.6"/>
      <path d="M230 144h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-6l-4 3v-3h-4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z" stroke="#44C2BA" stroke-width="1.3" stroke-linejoin="round" fill="none"/>
      <path d="M247 151l2.5-2.5a.8.8 0 0 1 1.2 0 .8.8 0 0 1 0 1.2l-2.5 2.5-1.8.6.6-1.8z" stroke="#44C2BA" stroke-width="1.1" stroke-linejoin="round" fill="none"/>
      <animate attributeName="opacity" values="0.8;1;0.8" dur="5s" repeatCount="indefinite" begin="0.6s"/>
    </g>
    <text x="240" y="128" text-anchor="middle" font-family="Space Mono, monospace" font-size="8" fill="#8BE6DA" opacity="0.7" letter-spacing="0.05em">BB_02</text>
    <text x="240" y="118" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="#8BE6DA" opacity="0.5">Client Blueprint</text>

    <!-- BB_03 Dynamic Context — top right -->
    <g class="graph-node" filter="url(#nodeGlow)">
      <circle cx="342" cy="211" r="20" fill="#0C1E1D" stroke="#44C2BA" stroke-width="1.6"/>
      <circle cx="338" cy="207" r="7.5" stroke="#44C2BA" stroke-width="1.5" fill="none"/>
      <line x1="343.3" y1="212.3" x2="349" y2="218" stroke="#44C2BA" stroke-width="1.8" stroke-linecap="round"/>
      <path d="M337.5 203.5l-1.5 3.5h3l-1.5 3.5" stroke="#44C2BA" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <animate attributeName="opacity" values="0.8;1;0.8" dur="4.5s" repeatCount="indefinite" begin="1.1s"/>
    </g>
    <text x="368" y="205" text-anchor="start" font-family="Space Mono, monospace" font-size="8" fill="#8BE6DA" opacity="0.7" letter-spacing="0.05em">BB_03</text>
    <text x="368" y="215" text-anchor="start" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="#8BE6DA" opacity="0.5">Dynamic Context</text>

    <!-- BB_04 Prompt Design — top left -->
    <g class="graph-node" filter="url(#nodeGlow)">
      <circle cx="138" cy="211" r="20" fill="#0C1E1D" stroke="#44C2BA" stroke-width="1.6"/>
      <rect x="128" y="202" width="20" height="18" rx="1.5" stroke="#44C2BA" stroke-width="1.3" fill="none"/>
      <line x1="128" y1="207.5" x2="148" y2="207.5" stroke="#44C2BA" stroke-width="1.2"/>
      <line x1="138" y1="207.5" x2="138" y2="220" stroke="#44C2BA" stroke-width="1.1"/>
      <line x1="131" y1="211" x2="136" y2="211" stroke="#44C2BA" stroke-width="0.9" stroke-linecap="round"/>
      <line x1="131" y1="214" x2="136" y2="214" stroke="#44C2BA" stroke-width="0.9" stroke-linecap="round"/>
      <line x1="140" y1="211" x2="146" y2="211" stroke="#44C2BA" stroke-width="0.9" stroke-linecap="round"/>
      <line x1="140" y1="214" x2="146" y2="214" stroke="#44C2BA" stroke-width="0.9" stroke-linecap="round"/>
      <animate attributeName="opacity" values="0.8;1;0.8" dur="3.8s" repeatCount="indefinite" begin="0.3s"/>
    </g>
    <text x="112" y="205" text-anchor="end" font-family="Space Mono, monospace" font-size="8" fill="#8BE6DA" opacity="0.7" letter-spacing="0.05em">BB_04</text>
    <text x="112" y="215" text-anchor="end" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="#8BE6DA" opacity="0.5">Prompt Design</text>

    <!-- BB_05 Tool Integration — bottom left -->
    <g class="graph-node" filter="url(#nodeGlow)">
      <circle cx="138" cy="329" r="20" fill="#0C1E1D" stroke="#44C2BA" stroke-width="1.6"/>
      <image href="/icons/bb-tool-integration.png" x="126" y="317" width="24" height="24" style="mix-blend-mode:screen"/>
      <animate attributeName="opacity" values="0.8;1;0.8" dur="5.5s" repeatCount="indefinite" begin="1.6s"/>
    </g>
    <text x="112" y="323" text-anchor="end" font-family="Space Mono, monospace" font-size="8" fill="#8BE6DA" opacity="0.7" letter-spacing="0.05em">BB_05</text>
    <text x="112" y="333" text-anchor="end" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="#8BE6DA" opacity="0.5">Tool Integration</text>

    <!-- BB_06 Model Engines — bottom center -->
    <g class="graph-node" filter="url(#nodeGlow)">
      <circle cx="240" cy="388" r="20" fill="#0C1E1D" stroke="#44C2BA" stroke-width="1.6"/>
      <image href="/icons/bb-model-engines.png" x="228" y="376" width="24" height="24" style="mix-blend-mode:screen"/>
      <animate attributeName="opacity" values="0.8;1;0.8" dur="4.8s" repeatCount="indefinite" begin="0.8s"/>
    </g>
    <text x="240" y="416" text-anchor="middle" font-family="Space Mono, monospace" font-size="8" fill="#8BE6DA" opacity="0.7" letter-spacing="0.05em">BB_06</text>
    <text x="240" y="426" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="#8BE6DA" opacity="0.5">Model Engines</text>

    <!-- BB_07 Evaluation Loop — bottom right, gold -->
    <g class="graph-node" filter="url(#nodeGlowGold)">
      <circle cx="342" cy="329" r="20" fill="#0C1E1D" stroke="#E9CA62" stroke-width="1.8"/>
      <circle cx="340" cy="329" r="8" stroke="#E9CA62" stroke-width="1.4" fill="none"/>
      <circle cx="340" cy="329" r="4.5" stroke="#E9CA62" stroke-width="1.3" fill="none"/>
      <circle cx="340" cy="329" r="1.5" fill="#E9CA62"/>
      <line x1="346" y1="323" x2="349" y2="320" stroke="#E9CA62" stroke-width="1.3" stroke-linecap="round"/>
      <line x1="346" y1="320" x2="350" y2="320" stroke="#E9CA62" stroke-width="1.3" stroke-linecap="round"/>
      <line x1="350" y1="320" x2="350" y2="324" stroke="#E9CA62" stroke-width="1.3" stroke-linecap="round"/>
      <animate attributeName="opacity" values="0.85;1;0.85" dur="4.2s" repeatCount="indefinite" begin="0.9s"/>
    </g>
    <text x="368" y="323" text-anchor="start" font-family="Space Mono, monospace" font-size="8" fill="#E9CA62" opacity="0.8" letter-spacing="0.05em">BB_07</text>
    <text x="368" y="333" text-anchor="start" font-family="Space Grotesk, sans-serif" font-size="8.5" fill="#E9CA62" opacity="0.55">Evaluation Loop</text>
  </svg>
</div>

<style>
  .hero-graph {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero-graph svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .graph-node {
    cursor: pointer;
  }

  .graph-node circle:first-child {
    transition: filter 0.3s;
  }

  .graph-node:hover circle:first-child {
    filter: drop-shadow(0 0 10px rgba(68, 194, 186, 0.9));
  }

  @media (max-width: 960px) {
    .hero-graph {
      margin-top: 0;
    }
  }
</style>
