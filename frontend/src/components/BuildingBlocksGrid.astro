---
const blocks = [
  { num: 'BB_01', name: 'Knowledge', desc: 'Menselijke expertise en competentie — de centrale kennislaag.',
    png: '/icons/bb-knowledge.png' },
  { num: 'BB_02', name: 'Client Blueprint', desc: 'End-to-end beschrijving van een AI-oplossing binnen klantcontext.',
    icon: '<rect x="4" y="2" width="12" height="16" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/><line x1="7" y1="6" x2="13" y2="6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/><line x1="7" y1="9" x2="13" y2="9" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/><line x1="7" y1="12" x2="11" y2="12" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>' },
  { num: 'BB_03', name: 'Dynamic Context', desc: 'Actuele, taakspecifieke informatie tijdens uitvoering via RAG en queries.',
    icon: '<circle cx="8.5" cy="8.5" r="5" stroke="currentColor" stroke-width="1.5" fill="none"/><line x1="12" y1="12" x2="17" y2="17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M8 6l-1 3h2.5L8 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>' },
  { num: 'BB_04', name: 'Prompt Design', desc: 'Ontwerp, structuur en verfijning van prompts voor betrouwbare output.',
    icon: '<rect x="2" y="2" width="16" height="16" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/><line x1="2" y1="7" x2="18" y2="7" stroke="currentColor" stroke-width="1.2"/><line x1="10" y1="7" x2="10" y2="18" stroke="currentColor" stroke-width="1.1"/><line x1="4.5" y1="10" x2="8" y2="10" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/><line x1="4.5" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/><line x1="12" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/><line x1="12" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>' },
  { num: 'BB_05', name: 'Tool Integration', desc: 'Koppeling van externe systemen, API\'s en databases aan de AI-oplossing.',
    png: '/icons/bb-tool-integration.png' },
  { num: 'BB_06', name: 'Model Engines', desc: 'AI-modellen en runtime-omgevingen die de kernfunctionaliteit aandrijven.',
    png: '/icons/bb-model-engines.png' },
  { num: 'BB_07', name: 'Evaluation Loop', desc: 'Continue cyclus van meten, leren en verbeteren op basis van echte resultaten.',
    icon: '<circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.3" fill="none"/><circle cx="10" cy="10" r="1.5" fill="currentColor"/><line x1="14" y1="6" x2="16" y2="4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="14" y1="4" x2="17" y2="4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="17" y1="4" x2="17" y2="7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>' },
];
---

<section class="blocks-section">
  <div class="eyebrow">Bouwstenen</div>
  <h2 class="section-title">7 Building Blocks</h2>
  <p class="section-intro">Elk AI-project bestaat uit dezelfde bouwstenen. BeeHaive maakt ze zichtbaar, meetbaar en verbeterbaar.</p>

  <div class="blocks-grid">
    <div class="block-card block-card-cta">
      <h3>Begin met het framework</h3>
      <p>Ontdek hoe de 7 bouwstenen samenwerken en start met je eerste AI-project.</p>
      <a href="/framework" class="btn-gold">Bekijk het framework →</a>
    </div>

    {blocks.map((block) => (
      <div class="block-card">
        <div class="block-gold-num">
          {block.png ? (
            <img class="block-icon-img" src={block.png} alt={block.name} />
          ) : (
            <svg class="block-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <Fragment set:html={block.icon} />
            </svg>
          )}
          {block.num}
        </div>
        <h3>{block.name}</h3>
        <p>{block.desc}</p>
        <span class="block-arrow">↗</span>
      </div>
    ))}
  </div>
</section>

<style>
  .blocks-section {
    background: var(--bg-2);
    padding: 4rem 5%;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .blocks-section::before {
    content: '';
    position: absolute;
    top: -180px;
    right: -180px;
    width: 580px;
    height: 580px;
    background: radial-gradient(circle, rgba(233, 202, 98, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .blocks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .block-card {
    background: var(--bg-2);
    padding: 2.2rem 2.4rem;
    position: relative;
    cursor: pointer;
    transition: background 0.3s;
    overflow: hidden;
  }

  .block-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--teal), var(--teal-light));
    box-shadow: 0 0 10px var(--teal);
    transition: width 0.4s ease;
  }

  .block-card:hover { background: var(--bg-3); }
  .block-card:hover::after { width: 100%; }

  .block-card-cta {
    background: linear-gradient(135deg, rgba(68, 194, 186, 0.13) 0%, rgba(139, 230, 218, 0.06) 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
  }

  .block-card-cta:hover {
    background: rgba(68, 194, 186, 0.18);
  }

  .block-card-cta h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--teal-light);
    margin-bottom: 0.55rem;
    letter-spacing: -0.02em;
  }

  .block-card-cta p {
    font-size: 0.87rem;
    color: var(--text-dim);
    line-height: 1.65;
    font-weight: 300;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .block-gold-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(233, 202, 98, 0.35);
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
    transition: color 0.3s;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .block-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--teal);
    opacity: 0.65;
    transition: opacity 0.3s, filter 0.3s;
  }

  .block-icon-img {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    object-fit: contain;
    opacity: 0.85;
    transition: opacity 0.3s, filter 0.3s;
  }

  .block-card:hover .block-icon,
  .block-card:hover .block-icon-img {
    opacity: 1;
    filter: drop-shadow(0 0 5px rgba(68, 194, 186, 0.6));
  }

  .block-card:hover .block-gold-num {
    color: var(--gold);
  }

  .block-card:not(.block-card-cta) h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.55rem;
    letter-spacing: -0.02em;
  }

  .block-card:not(.block-card-cta) p {
    font-size: 0.87rem;
    color: var(--text-muted);
    line-height: 1.65;
    font-weight: 300;
  }

  .block-arrow {
    position: absolute;
    top: 1.8rem;
    right: 2rem;
    font-size: 1rem;
    color: var(--text-muted);
    transition: color 0.3s, transform 0.3s;
  }

  .block-card:hover .block-arrow {
    color: var(--teal);
    transform: translate(3px, -3px);
  }

  @media (max-width: 960px) {
    .blocks-grid { grid-template-columns: 1fr; }
  }
</style>
