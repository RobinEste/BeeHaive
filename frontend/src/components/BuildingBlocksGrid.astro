---
import BBIcon from './bb-detail/BBIcon.astro';

const blocks = [
  { num: 'BB_01', name: 'Knowledge', slug: 'knowledge', desc: 'Menselijke expertise en competentie — de centrale kennislaag.' },
  { num: 'BB_02', name: 'Client Blueprint', slug: 'client-blueprint', desc: 'End-to-end beschrijving van een AI-oplossing binnen klantcontext.' },
  { num: 'BB_03', name: 'Dynamic Context', slug: 'dynamic-context', desc: 'Actuele, taakspecifieke informatie tijdens uitvoering via RAG en queries.' },
  { num: 'BB_04', name: 'Prompt Design', slug: 'prompt-design', desc: 'Ontwerp, structuur en verfijning van prompts voor betrouwbare output.' },
  { num: 'BB_05', name: 'Tool Integration', slug: 'tool-integration', desc: 'Koppeling van externe systemen, API\'s en databases aan de AI-oplossing.' },
  { num: 'BB_06', name: 'Model Engines', slug: 'model-engines', desc: 'AI-modellen en runtime-omgevingen die de kernfunctionaliteit aandrijven.' },
  { num: 'BB_07', name: 'Evaluation Loop', slug: 'evaluation-loop', desc: 'Continue cyclus van meten, leren en verbeteren op basis van echte resultaten.' },
];
---

<section class="blocks-section">
  <div class="eyebrow">Bouwstenen</div>
  <h2 class="section-title">7 Building Blocks</h2>
  <p class="section-intro">Elk AI-project bestaat uit dezelfde bouwstenen. BeeHaive maakt ze zichtbaar, meetbaar en verbeterbaar.</p>

  <div class="blocks-grid">
    <div class="block-card block-card-cta">
      <h3>Begin met het framework</h3>
      <p>Ontdek hoe de 7 bouwstenen samenwerken en start met je eerste AI-project.</p>
      <a href="/framework" class="btn-gold" style="font-size: 0.85rem; padding: 0.65rem 1.4rem;">Bekijk het framework →</a>
    </div>

    {blocks.map((block) => (
      <a href={`/framework/${block.slug}`} class="block-card">
        <div class="block-gold-num">
          <BBIcon slug={block.slug} size={18} class="block-icon" />
          {block.num}
        </div>
        <h3>{block.name}</h3>
        <p>{block.desc}</p>
        <span class="block-arrow">↗</span>
      </a>
    ))}
  </div>
</section>

<style>
  .blocks-section {
    background: linear-gradient(rgba(18, 44, 42, 0.92), rgba(12, 30, 29, 0.95)), url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80') center/cover no-repeat;
    padding: 4rem 5%;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .blocks-section::before {
    content: '';
    position: absolute;
    top: -180px;
    right: -180px;
    width: 580px;
    height: 580px;
    background: radial-gradient(circle, rgba(233, 202, 98, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .blocks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .block-card {
    background: var(--bg-2);
    padding: 2.2rem 2.4rem;
    position: relative;
    cursor: pointer;
    transition: background 0.3s;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .block-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--teal), var(--teal-light));
    box-shadow: 0 0 10px var(--teal);
    transition: width 0.4s ease;
  }

  .block-card:hover { background: var(--bg-3); }
  .block-card:hover::after { width: 100%; }

  .block-card-cta {
    background: linear-gradient(135deg, rgba(68, 194, 186, 0.13) 0%, rgba(139, 230, 218, 0.06) 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .block-card-cta:hover {
    background: rgba(68, 194, 186, 0.18);
  }

  .block-card-cta h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--teal-light);
    margin-bottom: 0.55rem;
    letter-spacing: -0.02em;
  }

  .block-card-cta p {
    font-size: 0.87rem;
    color: var(--text-dim);
    line-height: 1.65;
    font-weight: 300;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .block-gold-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(233, 202, 98, 0.35);
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
    transition: color 0.3s;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .block-gold-num :global(.block-icon) {
    opacity: 0.65;
    transition: opacity 0.3s, filter 0.3s;
  }

  .block-card:hover .block-gold-num :global(.block-icon) {
    opacity: 1;
    filter: drop-shadow(0 0 5px rgba(68, 194, 186, 0.6));
  }

  .block-card:hover .block-gold-num {
    color: var(--gold);
  }

  .block-card:not(.block-card-cta) h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.55rem;
    letter-spacing: -0.02em;
  }

  .block-card:not(.block-card-cta) p {
    font-size: 0.87rem;
    color: var(--text-muted);
    line-height: 1.65;
    font-weight: 300;
  }

  .block-arrow {
    position: absolute;
    top: 1.8rem;
    right: 2rem;
    font-size: 1rem;
    color: var(--text-muted);
    transition: color 0.3s, transform 0.3s;
  }

  .block-card:hover .block-arrow {
    color: var(--teal);
    transform: translate(3px, -3px);
  }

  @media (max-width: 960px) {
    .blocks-grid { grid-template-columns: 1fr; }
  }
</style>
