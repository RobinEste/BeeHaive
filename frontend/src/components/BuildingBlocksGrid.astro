---
import BBIcon from './bb-detail/BBIcon.astro';

const blocks = [
  { num: 'BB_01', name: 'Knowledge', slug: 'knowledge', desc: 'Menselijke expertise en competentie — de centrale kennislaag.' },
  { num: 'BB_02', name: 'Client Blueprint', slug: 'client-blueprint', desc: 'End-to-end beschrijving van een AI-oplossing binnen klantcontext.' },
  { num: 'BB_03', name: 'Dynamic Context', slug: 'dynamic-context', desc: 'Actuele, taakspecifieke informatie tijdens uitvoering via RAG en queries.' },
  { num: 'BB_04', name: 'Prompt Design', slug: 'prompt-design', desc: 'Ontwerp, structuur en verfijning van prompts voor betrouwbare output.' },
  { num: 'BB_05', name: 'Tool Integration', slug: 'tool-integration', desc: 'Koppeling van externe systemen, API\'s en databases aan de AI-oplossing.' },
  { num: 'BB_06', name: 'Model Engines', slug: 'model-engines', desc: 'AI-modellen en runtime-omgevingen die de kernfunctionaliteit aandrijven.' },
  { num: 'BB_07', name: 'Evaluation Loop', slug: 'evaluation-loop', desc: 'Continue cyclus van meten, leren en verbeteren op basis van echte resultaten.' },
];
---

<section class="blocks-section scroll-reveal">
  <div class="eyebrow">Bouwstenen</div>
  <h2 class="section-title">7 Building Blocks</h2>
  <a href="/framework" class="btn-gold section-cta">Bekijk het framework →</a>
  <p class="section-intro">Elk AI-project bestaat uit dezelfde bouwstenen. BeeHaive maakt ze zichtbaar, meetbaar en verbeterbaar.</p>

  <div class="blocks-grid scroll-reveal-stagger">
    {blocks.map((block) => (
      <a href={`/framework/${block.slug}`} class="block-card" data-bb={block.slug}>
        <div class="block-header">
          <BBIcon slug={block.slug} size={22} class="block-icon" />
          <h3>{block.name}</h3>
          <span class="block-num">{block.num}</span>
        </div>
        <p>{block.desc}</p>
        <span class="block-arrow">↗</span>
      </a>
    ))}
  </div>
</section>

<style>
  .blocks-section {
    background: linear-gradient(rgba(18, 44, 42, 0.92), rgba(12, 30, 29, 0.95)), url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80') center/cover no-repeat;
    padding: 4rem 5%;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .blocks-section::before {
    content: '';
    position: absolute;
    top: -180px;
    right: -180px;
    width: 580px;
    height: 580px;
    background: radial-gradient(circle, rgba(233, 202, 98, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .blocks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .section-cta {
    font-size: 0.85rem;
    padding: 0.65rem 1.4rem;
    margin-bottom: 0.75rem;
  }

  /* ── Per-BB kleur via data-attribuut ── */
  .block-card[data-bb="knowledge"]       { --accent: var(--bb-knowledge); }
  .block-card[data-bb="client-blueprint"]{ --accent: var(--bb-client-blueprint); }
  .block-card[data-bb="dynamic-context"] { --accent: var(--bb-dynamic-context); }
  .block-card[data-bb="prompt-design"]   { --accent: var(--bb-prompt-design); }
  .block-card[data-bb="tool-integration"]{ --accent: var(--bb-tool-integration); }
  .block-card[data-bb="model-engines"]   { --accent: var(--bb-model-engines); }
  .block-card[data-bb="evaluation-loop"] { --accent: var(--bb-evaluation-loop); }

  /* ── Card base ── */
  .block-card {
    background: var(--bg-2);
    border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
    border-left: 3px solid color-mix(in srgb, var(--accent) 40%, transparent);
    border-radius: 14px;
    padding: 2.2rem 2.4rem;
    position: relative;
    cursor: pointer;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: background 0.3s, border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  /* Subtiele achtergrondtint per kleur */
  .block-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, color-mix(in srgb, var(--accent) 12%, transparent), transparent 70%);
    pointer-events: none;
    transition: opacity 0.3s;
    opacity: 0.5;
  }

  /* ── Hover ── */
  .block-card:hover {
    background: var(--bg-3);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    border-left-color: var(--accent);
    transform: translateY(-4px);
    box-shadow:
      0 0 30px color-mix(in srgb, var(--accent) 15%, transparent),
      0 12px 32px rgba(0, 0, 0, 0.3);
  }

  .block-card:hover::before {
    opacity: 1;
  }

  /* ── Header ── */
  .block-header {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.55rem;
    position: relative;
  }

  .block-header :global(.block-icon) {
    opacity: 0.7;
    transition: opacity 0.3s, filter 0.3s;
  }

  .block-card:hover .block-header :global(.block-icon) {
    opacity: 1;
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--accent) 60%, transparent));
  }

  .block-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: color-mix(in srgb, var(--accent) 55%, transparent);
    letter-spacing: 0.12em;
    transition: color 0.3s;
  }

  .block-card:hover .block-num {
    color: var(--accent);
  }

  .block-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.02em;
    position: relative;
  }

  .block-card p {
    font-size: 0.87rem;
    color: var(--text-muted);
    line-height: 1.65;
    font-weight: 300;
    position: relative;
  }

  .block-arrow {
    position: absolute;
    top: 1.8rem;
    right: 2rem;
    font-size: 1rem;
    color: var(--text-muted);
    transition: color 0.3s, transform 0.3s;
  }

  .block-card:hover .block-arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }

  @media (max-width: 960px) {
    .blocks-grid { grid-template-columns: 1fr; }
  }
</style>
