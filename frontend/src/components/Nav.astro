---
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <a href="/">
    <img src="/logo.png" alt="BeeHaive" class="nav-logo" />
  </a>
  <ul class="nav-links">
    <li><a href="/framework" class:list={[{ active: currentPath === '/framework' }]}>Framework</a></li>
    <li><a href="/kennisbank" class:list={[{ active: currentPath === '/kennisbank' }]}>Kennisbank</a></li>
    <li><a href="/over" class:list={[{ active: currentPath === '/over' }]}>Over ons</a></li>
    <li><a href="/framework" class="nav-cta">Aan de slag</a></li>
  </ul>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(12, 30, 29, 0.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 5%;
    height: 70px;
  }

  .nav-logo {
    height: 48px;
    width: auto;
  }

  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2.2rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text-dim);
    font-weight: 500;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--teal);
  }

  .nav-cta {
    background: var(--teal) !important;
    color: var(--bg) !important;
    padding: 0.5rem 1.4rem;
    border-radius: 6px;
    font-weight: 700 !important;
    letter-spacing: 0.03em;
    transition: box-shadow 0.3s, transform 0.2s !important;
  }

  .nav-cta:hover {
    box-shadow: 0 0 22px rgba(68, 194, 186, 0.5) !important;
    transform: translateY(-2px);
    color: var(--bg) !important;
  }

  @media (max-width: 960px) {
    .nav-links { display: none; }
  }
</style>
