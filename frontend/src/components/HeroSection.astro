---
import KnowledgeGraph from './KnowledgeGraph.astro';
---

<section class="hero">
  <div class="hero-inner">
    <h1>
      <span class="h1-white">AI begrijpen.</span>
      <span class="h1-teal">AI toepassen.</span>
      <span class="h1-gold">AI vertrouwen.</span>
    </h1>
    <p class="hero-sub">Succesvolle toepassing van AI ontstaat door zeven samenhangende bouwstenen consistent in te zetten en te blijven verbeteren. Deze bouwstenen vormen de "knoppen waaraan je kunt draaien" tijdens ontwerp, ontwikkeling, implementatie en gebruik.</p>
    <p class="hero-sub">Het BeeHaive-framework helpt om te begrijpen hoe je aan die knoppen kunt draaien, welke bouwstenen je wanneer kunt inzetten en aan welke waarborgen (guardrails) je moet voldoen om AI succesvol toe te passen.</p>
    <div class="hero-actions">
      <a href="/framework" class="btn-gold">Ontdek het framework →</a>
      <a href="/kennisbank" class="btn-ghost">Verken de kennisbank</a>
    </div>
  </div>

  <div class="hero-graph-col">
    <div class="hero-chip animate-fade-up">
      <span class="chip-pulse"></span>
      AI Knowledge Framework by Noblesse Oblige
    </div>
    <KnowledgeGraph />
  </div>

  <div class="orb orb-teal"></div>
  <div class="orb orb-gold"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: auto;
    display: grid;
    grid-template-columns: 1fr 680px;
    align-items: start;
    padding: 3rem 5% 3rem;
    gap: 2rem;
    overflow: hidden;
  }

  .hero-graph-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero-graph-col .hero-chip {
    margin-top: 2rem;
    margin-bottom: 0.3rem;
  }

  .orb {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
  }

  .orb-teal {
    top: -120px;
    right: -100px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(68, 194, 186, 0.13) 0%, transparent 65%);
    animation: lumPulse 7s ease-in-out infinite alternate;
  }

  .orb-gold {
    bottom: -100px;
    left: 5%;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(233, 202, 98, 0.08) 0%, transparent 65%);
    animation: lumPulse 9s 2s ease-in-out infinite alternate;
  }

  @keyframes lumPulse {
    from { opacity: 0.8; transform: scale(1); }
    to   { opacity: 1;   transform: scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .h1-teal  { display: block; color: var(--teal); }
  .h1-gold  { display: block; color: var(--gold); text-shadow: 0 0 60px rgba(233, 202, 98, 0.22); }
  .h1-white { display: block; color: var(--text); }

  .hero-sub {
    font-size: 1.12rem;
    line-height: 1.8;
    color: var(--text-dim);
    max-width: 580px;
    margin: 1rem 0 1rem;
    font-weight: 300;
    animation: fadeUp 0.5s 0.2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s 0.3s ease both;
  }

  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 2rem 5% 2rem;
    }

    .hero-graph-col {
      order: 1;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
    }

    .hero-graph-col .hero-chip {
      margin-top: 0;
    }

    .hero-inner {
      text-align: center;
    }

    .hero-sub {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }
  }
</style>
